{
  "name": "@repo/sdk",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "openapi-ts -f openapi-ts.config.local.ts",
    "generate:local": "openapi-ts -f openapi-ts.config.local.ts",
    "clean": "rm -rf dist src/api"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.10.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.95.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}